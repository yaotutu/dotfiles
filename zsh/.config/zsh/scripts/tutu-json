#!/usr/bin/env bash
set -euo pipefail

# ----------------------------------------------------------------------
# tutu-json — 格式化 JSON（支持管道输入或文件参数）
# 用法: echo '{"a":1}' | tutu-json
#       tutu-json <file.json>
# ----------------------------------------------------------------------

if [[ -n "${1:-}" ]]; then
    # 从文件读取
    if [[ ! -f "$1" ]]; then
        echo "文件不存在: $1"
        exit 1
    fi
    cat "$1" | python3 -m json.tool
else
    # 从管道读取
    python3 -m json.tool
fi
