#!/usr/bin/env bash
set -euo pipefail

# ----------------------------------------------------------------------
# tutu-gitlog — 美化 git log，一行一个提交带分支图
# 用法: tutu-gitlog [数量]  默认显示 20 条
# ----------------------------------------------------------------------
count="${1:-20}"

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "不在 git 仓库中"
    exit 1
fi

git log --graph --pretty=format:'%C(red)%h%C(reset) %C(green)%cr%C(reset) %C(bold)%s%C(reset) %C(dim)%an%C(reset)' --date=relative -"$count"
echo ""
